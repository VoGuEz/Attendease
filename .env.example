# ─────────────────────────────────────────────────────────────────────────────
# AttendEase – Environment Variable Reference
#
# Copy this file to .env for local development (never commit .env to git).
# On Railway, set these as service variables in the Railway dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# Server port (Railway sets PORT automatically; leave as 8080 for local dev)
PORT=8080

# ─────────────────────────────────────────────────────────────────────────────
# SMTP / Email Settings (for password reset emails)
# ─────────────────────────────────────────────────────────────────────────────
# For Gmail: use smtp.gmail.com / 587 and an App Password (not your login password).
#   1. Enable 2-Step Verification on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Generate an App Password for "Mail" and paste it below
#
# For Yahoo: use smtp.mail.yahoo.com / 587 and an App Password.
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# ── MySQL connection ─────────────────────────────────────────────────────────
# When using the Railway MySQL plugin the values below are auto-populated via
# the MYSQL* variables.  You can also set DB_* variables directly.
#
# Option A – Railway MySQL plugin (values injected automatically):
#   MYSQLHOST, MYSQLPORT, MYSQLDATABASE, MYSQLUSER, MYSQLPASSWORD
#
# Option B – Custom / local MySQL:
DB_HOST=localhost
DB_PORT=3306
DB_NAME=attendease
DB_USER=root
DB_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens. Change this to a long random string
# before deploying to production.
JWT_SECRET=change-me-to-a-long-random-secret
